auto lo
iface lo inet loopback

iface nic0 inet manual

{% if management_interface != 'nic0' %}
iface {{ management_interface }} inet manual
{% endif %}

auto {{ management_bridge }}
iface {{ management_bridge }} inet static
	address {{ management_cidr }}
	gateway {{ management_gateway }}
	bridge-ports {{ management_interface }}
	bridge-stp off
	bridge-fd 0


source /etc/network/interfaces.d/*
