#!/bin/sh
set -eu

INTERFACE="{{ management_interface }}"
STATE_DIR="/var/lib/homelab-management-nic"
LOG_DIR="/var/log/homelab-management-nic"
STATE_FILE="$STATE_DIR/watchdog.env"
RESET_LOG="$LOG_DIR/watchdog-resets.log"
LAST_EVENT_FILE="$STATE_DIR/last-hang-event.txt"
WATCHDOG_INTERVAL="{{ management_interface_tuning.watchdog_interval_seconds | default(30) }}"
COOLDOWN_SECONDS="{{ management_interface_tuning.watchdog_cooldown_seconds | default(300) }}"
MAX_RESETS_PER_HOUR="{{ management_interface_tuning.watchdog_max_resets_per_hour | default(6) }}"
NOW="$(date +%s)"

mkdir -p "$STATE_DIR" "$LOG_DIR"

LAST_RESET_EPOCH=0
if [ -f "$STATE_FILE" ]; then
  # shellcheck disable=SC1090
  . "$STATE_FILE"
fi

HANG_EVENT="$(
  journalctl -k -b -o short-unix --no-pager \
    | grep "e1000e .* ${INTERFACE}: Detected Hardware Unit Hang" \
    | tail -n 1
)"

if [ -z "$HANG_EVENT" ]; then
  exit 0
fi

LAST_HANDLED_EVENT=""
if [ -f "$LAST_EVENT_FILE" ]; then
  LAST_HANDLED_EVENT="$(cat "$LAST_EVENT_FILE")"
fi

if [ "$HANG_EVENT" = "$LAST_HANDLED_EVENT" ]; then
  exit 0
fi

if [ "${LAST_RESET_EPOCH:-0}" -gt 0 ] && [ $((NOW - LAST_RESET_EPOCH)) -lt "$COOLDOWN_SECONDS" ]; then
  printf '%s cooldown_active event=%s\n' "$(date --iso-8601=seconds)" "$HANG_EVENT" >> "$RESET_LOG"
  exit 0
fi

WINDOW_START=$((NOW - 3600))
RESET_COUNT_LAST_HOUR=0
if [ -f "$RESET_LOG" ]; then
  RESET_COUNT_LAST_HOUR="$(
    awk -v window_start="$WINDOW_START" '
      {
        if ($1 ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}T/) {
          cmd = "date -d \"" $1 "\" +%s"
          cmd | getline epoch
          close(cmd)
          if (epoch >= window_start && $2 == "reset_triggered") {
            count += 1
          }
        }
      }
      END { print count + 0 }
    ' "$RESET_LOG"
  )"
fi

if [ "$RESET_COUNT_LAST_HOUR" -ge "$MAX_RESETS_PER_HOUR" ]; then
  printf '%s reset_rate_limited count=%s event=%s\n' \
    "$(date --iso-8601=seconds)" "$RESET_COUNT_LAST_HOUR" "$HANG_EVENT" >> "$RESET_LOG"
  exit 0
fi

/usr/local/sbin/capture-management-nic-diagnostics watchdog-pre-reset >/dev/null

printf '%s reset_triggered event=%s\n' "$(date --iso-8601=seconds)" "$HANG_EVENT" >> "$RESET_LOG"
ip link set "$INTERFACE" down
sleep 3
ip link set "$INTERFACE" up

cat > "$STATE_FILE" <<EOF
LAST_RESET_EPOCH=$NOW
EOF
printf '%s\n' "$HANG_EVENT" > "$LAST_EVENT_FILE"

sleep 5
/usr/local/sbin/capture-management-nic-diagnostics watchdog-post-reset >/dev/null
