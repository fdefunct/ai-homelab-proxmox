# Runtime-injected secrets from 1Password.
# Render with `op inject -i terraform/envs/home/secrets.tfvars.template`.
# These credentials are the steady-state Terraform identity, not the Day 0 bootstrap SSH identity.

proxmox_api_token = "op://Homelab/pve-0-terraform/credential"

proxmox_ssh_username = "op://Homelab/homelab-ops/username"

proxmox_ssh_private_key = <<-EOT
op://Homelab/homelab-ops/private key
EOT

cluster_operator_ssh_public_key = "op://Homelab/homelab-ops/public key"
