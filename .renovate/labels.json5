{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchUpdateTypes: ["major"],
      labels: ["type/major"],
    },
    {
      matchUpdateTypes: ["minor"],
      labels: ["type/minor"],
    },
    {
      matchUpdateTypes: ["patch"],
      labels: ["type/patch"],
    },
    {
      matchUpdateTypes: ["digest"],
      labels: ["type/digest"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate", "area/github"],
    },
    {
      matchManagers: ["custom.regex", "helm-values", "kubernetes"],
      addLabels: ["renovate", "area/kubernetes"],
    },
    {
      matchManagers: ["ansible-galaxy"],
      addLabels: ["renovate", "area/ansible"],
    },
    {
      matchManagers: ["terraform"],
      addLabels: ["renovate", "area/terraform"],
    },
  ],
}
