#!/usr/bin/env python3
from pathlib import Path
import os
import re
import sys

import yaml


REFERENCE_PATTERN = re.compile(r"op://[^\"\n]+")
ENV_NAME = os.environ.get("ENV_NAME") or (sys.argv[1] if len(sys.argv) > 1 else "home")

ALLOWED_FILES = {
    "ansible/secrets.yml",
    "ansible/bootstrap-ssh-private-key",
    "ansible/bootstrap-ssh-user",
    "ansible/operator-ssh-private-key",
    "ansible/argocd-repo-private-key",
    f"terraform/envs/{ENV_NAME}/secrets.tfvars.template",
}
ALLOWED_OWNERS = {
    "terraform",
    "bootstrap",
    "ansible",
    "argocd-bootstrap",
    "gitops",
}


def load_catalog(path: Path):
    data = yaml.safe_load(path.read_text())
    if not isinstance(data, dict):
        raise ValueError(f"{path}: expected top-level YAML object")

    references = data.get("references")
    if not isinstance(references, list) or not references:
        raise ValueError(f"{path}: expected non-empty references list")

    return references


def load_environment_config(repo_root: Path, env_name: str):
    path = repo_root / "config" / f"{env_name}.yaml"
    data = yaml.safe_load(path.read_text())
    if not isinstance(data, dict):
        raise ValueError(f"{path}: expected top-level YAML object")

    platform = data.get("platform")
    if not isinstance(platform, dict):
        raise ValueError(f"{path}: missing required platform configuration")

    vault = platform.get("onepassword_vault")
    if not isinstance(vault, str) or not vault.strip():
        raise ValueError(f"{path}: platform.onepassword_vault must be a non-empty string")

    return vault


def find_repo_references(repo_root: Path):
    refs_by_file: dict[str, set[str]] = {}
    for rel_path in sorted(ALLOWED_FILES):
        path = repo_root / rel_path
        matches = set(REFERENCE_PATTERN.findall(path.read_text()))
        refs_by_file[rel_path] = matches
    return refs_by_file


def find_unexpected_reference_files(repo_root: Path):
    unexpected: dict[str, set[str]] = {}
    for path in sorted(repo_root.rglob("*")):
        if not path.is_file():
            continue
        if path.parts[len(repo_root.parts)] in {".git", ".venv", ".ansible"}:
            continue

        rel_path = path.relative_to(repo_root).as_posix()
        if rel_path in ALLOWED_FILES:
            continue
        if rel_path.startswith("docs/"):
            continue
        if rel_path.endswith(".md"):
            continue
        if rel_path in {"scripts/validate-secret-catalog", "scripts/assert-rendered-secrets"}:
            continue

        try:
            text = path.read_text()
        except UnicodeDecodeError:
            continue

        matches = set(REFERENCE_PATTERN.findall(text))
        if matches:
            unexpected[rel_path] = matches
    return unexpected


def main():
    repo_root = Path(__file__).resolve().parent.parent
    catalog_path = repo_root / "docs" / "secret-catalog.yaml"
    errors: list[str] = []

    try:
        entries = load_catalog(catalog_path)
        expected_vault = load_environment_config(repo_root, ENV_NAME)
    except (OSError, ValueError, yaml.YAMLError) as exc:
        print(str(exc), file=sys.stderr)
        raise SystemExit(1)

    refs_by_file = find_repo_references(repo_root)
    repo_refs = {ref for refs in refs_by_file.values() for ref in refs}
    catalog_refs: dict[str, dict] = {}

    for index, entry in enumerate(entries, start=1):
        if not isinstance(entry, dict):
            errors.append(f"{catalog_path}: references[{index}] must be an object")
            continue

        ref = entry.get("ref")
        owner = entry.get("owner")
        purpose = entry.get("purpose")
        consumers = entry.get("consumers")

        if not isinstance(ref, str) or not ref.startswith("op://"):
            errors.append(f"{catalog_path}: references[{index}].ref must be an op:// string")
            continue
        if ref in catalog_refs:
            errors.append(f"{catalog_path}: duplicate catalog entry for {ref}")
            continue
        if not ref.startswith(f"op://{expected_vault}/"):
            errors.append(f"{catalog_path}: {ref} must live under vault {expected_vault}")

        if owner not in ALLOWED_OWNERS:
            errors.append(f"{catalog_path}: {ref} has invalid owner {owner!r}")
        if not isinstance(purpose, str) or not purpose.strip():
            errors.append(f"{catalog_path}: {ref} must declare a non-empty purpose")
        if not isinstance(consumers, list) or not consumers:
            errors.append(f"{catalog_path}: {ref} must declare at least one consumer")
            consumers = []

        # gitops-owned secrets flow through ExternalSecret manifests using item key
        # references, not op:// URIs, so they never appear in ALLOWED_FILES.
        # Accept any string consumer for gitops entries and exclude them from
        # the repo-usage check below.
        is_gitops = owner == "gitops"

        normalized_consumers = set()
        for consumer in consumers:
            if not isinstance(consumer, str):
                errors.append(f"{catalog_path}: {ref} consumer entries must be strings")
                continue
            if not is_gitops and consumer not in ALLOWED_FILES:
                errors.append(f"{catalog_path}: {ref} declares non-approved consumer {consumer}")
                continue
            normalized_consumers.add(consumer)

        catalog_refs[ref] = {
            "owner": owner,
            "is_gitops": is_gitops,
            "consumers": normalized_consumers,
        }

    unexpected_files = find_unexpected_reference_files(repo_root)
    for rel_path, refs in unexpected_files.items():
        errors.append(f"{rel_path}: unexpected 1Password reference(s): {', '.join(sorted(refs))}")

    missing_catalog_refs = sorted(repo_refs - set(catalog_refs))
    for ref in missing_catalog_refs:
        errors.append(f"{catalog_path}: missing catalog entry for {ref}")

    for ref in sorted(repo_refs):
        if not ref.startswith(f"op://{expected_vault}/"):
            errors.append(f"{ref}: secret reference must live under vault {expected_vault}")

    # Exclude gitops-owned refs: they're consumed by ExternalSecret manifests via
    # item key references, not op:// URIs, so they won't appear in repo_refs.
    tracked_refs = {ref for ref, entry in catalog_refs.items() if not entry.get("is_gitops")}
    stale_catalog_refs = sorted(tracked_refs - repo_refs)
    for ref in stale_catalog_refs:
        errors.append(f"{catalog_path}: catalog entry not used in repo: {ref}")

    for rel_path, refs in refs_by_file.items():
        for ref in sorted(refs):
            declared_consumers = catalog_refs.get(ref, {}).get("consumers", set())
            if rel_path not in declared_consumers:
                errors.append(f"{catalog_path}: {ref} is used by {rel_path} but that consumer is not declared")

    for ref, entry in catalog_refs.items():
        if entry.get("is_gitops"):
            continue  # gitops consumers are k8s manifests, not op:// reference files
        for consumer in sorted(entry["consumers"]):
            if ref not in refs_by_file.get(consumer, set()):
                errors.append(f"{catalog_path}: {ref} declares unused consumer {consumer}")

    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        raise SystemExit(1)

    print("Secret catalog validation passed")


if __name__ == "__main__":
    main()
