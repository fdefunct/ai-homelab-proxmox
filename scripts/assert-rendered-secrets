#!/bin/bash
set -euo pipefail

FILE_PATH="${1:-}"
LABEL="${2:-rendered secrets}"

if [ -z "$FILE_PATH" ]; then
  printf 'Usage: %s <file> [label]\n' "$0" >&2
  exit 1
fi

if [ ! -s "$FILE_PATH" ]; then
  printf '%s are empty: %s\n' "$LABEL" "$FILE_PATH" >&2
  exit 1
fi

if grep -n 'op://' "$FILE_PATH" >/dev/null 2>&1; then
  printf '%s still contain unresolved 1Password references: %s\n' "$LABEL" "$FILE_PATH" >&2
  exit 1
fi
