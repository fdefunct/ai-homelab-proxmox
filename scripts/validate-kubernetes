#!/usr/bin/env python3
from pathlib import Path
import os
import sys

from validate_kubernetes_apps import validate as validate_apps
from validate_kubernetes_common import load_environment_config
from validate_kubernetes_platform import validate as validate_platform
from validate_kubernetes_renovate import validate as validate_renovate


ENV_NAME = os.environ.get("ENV_NAME") or (sys.argv[1] if len(sys.argv) > 1 else "home")


def main():
    repo_root = Path(__file__).resolve().parent.parent
    config = load_environment_config(repo_root, ENV_NAME)
    errors: list[str] = []

    validate_apps(repo_root, config, errors)
    validate_platform(repo_root, config, errors)
    validate_renovate(repo_root, config, errors)

    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        raise SystemExit(1)

    print("Kubernetes validation passed")


if __name__ == "__main__":
    main()
